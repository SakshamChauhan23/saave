# Copy to .env.local and fill in values from `supabase start` output.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Must match the host you use in the browser (and supabase `site_url` origin).
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
# Server-only — never expose via NEXT_PUBLIC_*. Used only by the Phase 2 AI
# extraction background job (lib/ai/extract.ts) to decrypt a user's own
# Vault-stored provider key via the get_ai_provider_key() RPC. Never use this
# key in a client-facing request path.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key